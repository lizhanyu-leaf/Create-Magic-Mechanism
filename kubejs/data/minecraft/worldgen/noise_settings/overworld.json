{
  "sea_level": -64,
  "disable_mob_generation": false,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,
  "default_block": {
    "Name": "minecraft:stone"
  },
  "default_fluid": {
    "Name": "minecraft:air"
  },
  "noise": {
    "min_y": -64,
    "height": 64,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "barrier": { "type": "minecraft:constant", "argument": 0 },
    "fluid_level_floodedness": { "type": "minecraft:constant", "argument": 0 },
    "fluid_level_spread": { "type": "minecraft:constant", "argument": 0 },
    "lava": { "type": "minecraft:constant", "argument": 0 },
    "vein_toggle": { "type": "minecraft:constant", "argument": 0 },
    "vein_ridged": { "type": "minecraft:constant", "argument": 0 },
    "vein_gap": { "type": "minecraft:constant", "argument": 0 },
    "temperature": {
      "type": "minecraft:shifted_noise",
      "noise": "minecraft:temperature",
      "shift_x": "minecraft:shift_x",
      "shift_y": 0.0,
      "shift_z": "minecraft:shift_z",
      "xz_scale": 0.25,
      "y_scale": 0.0
    },
    "vegetation": {
      "type": "minecraft:shifted_noise",
      "noise": "minecraft:vegetation",
      "shift_x": "minecraft:shift_x",
      "shift_y": 0.0,
      "shift_z": "minecraft:shift_z",
      "xz_scale": 0.25,
      "y_scale": 0.0
    },
    "continents": "minecraft:overworld/continents",
    "depth": "minecraft:overworld/depth",
    "erosion": "minecraft:overworld/erosion",
    "ridges": "minecraft:overworld/ridges",
    "initial_density_without_jaggedness": {
      "type": "minecraft:range_choice",
      "input": "minecraft:y",
      "min_inclusive": -64,
      "max_exclusive": 0,
      "when_in_range": { "type": "minecraft:constant", "argument": 1 },
      "when_out_of_range": { "type": "minecraft:constant", "argument": -1 }
    },
    "final_density": {
      "type": "minecraft:range_choice",
      "input": "minecraft:y",
      "min_inclusive": -64,
      "max_exclusive": 0,
      "when_in_range": { "type": "minecraft:constant", "argument": 1 },
      "when_out_of_range": { "type": "minecraft:constant", "argument": -1 }
    },
    "vein_ridged_folded": { "type": "minecraft:constant", "argument": 0 }
  },
  "spawn_target": [],
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:biome",
          "biome_is": ["kubejs:stone_rich"]
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:stone" }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:y_above",
          "anchor": { "above_bottom": 63 },
          "surface_depth_multiplier": 0,
          "add_stone_depth": false,
          "add_surface_depth": false,
          "add_surface_secondary_depth": false
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:grass_block" }
        }
      },
      {
        "type": "minecraft:block",
        "result_state": { "Name": "minecraft:stone" }
      }
    ]
  }
}